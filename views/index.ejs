<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <% if(error.length>0) { %>
        <div class="absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-red-500" >
            <span class="inline-block mt-1 mb-1 text-white" >
                <%= error%>
            </span>
        </div>
    <% } %>

    <div class=" w-full h-screen flex px-20" >
       <div class="w-1/2 flex items-center justify-center h-screen">
            <div class="w-full px-32">
                <h3 class="text-4xl mb-2">Welcome to <span class="text-blue-400 font-semibold">BagNest</span></h3>
                <h4 class="text-2xl mb-5">Register your Account</h4>
                <form autocomplete="off" action="/users/register" method="post">
                    <input
                    class="bg-zinc-100 block w-full px-2 py-2 border-[1px] rounded-md mb-3 border-2" 
                    type="text" placeholder="Username" name="username">
                    <input
                    class="bg-zinc-100 block w-full px-2 py-2 border-[1px] rounded-md mb-3 border-2" 
                    type="email" placeholder="Email" name="email">
                    <input
                    class="bg-zinc-100 block w-full px-2 py-2 border-[1px] rounded-md mb-3 border-2" 
                    type="password" placeholder="Password" name="password">
                    <input
                    class="px-5 py-3 rounded-full py-3 mt-2 bg-blue-500 text-white" 
                    type="submit">
                </form>
            </div>
            <div class="w-full px-32">
                <h4 class="text-3xl mb-5 text-blue-500">Login your Account</h4>
                <form autocomplete="off" action="/users/login" method="post">
                    <input
                    class="bg-zinc-100 block w-full px-2 py-2 border-[1px] rounded-md mb-3 border-2" 
                    type="email" placeholder="Email" name="email">
                    <input
                    class="bg-zinc-100 block w-full px-2 py-2 border-[1px] rounded-md mb-3 border-2" 
                    type="password" placeholder="Password" name="password">
                    <input
                    class="px-5 py-3 rounded-full py-3 mt-2 bg-blue-500 text-white" 
                    type="submit">
                </form>
            </div>
       </div>
    </div>
</body>
</html>