<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | BagNest</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

    <!-- Navbar -->
    <nav class="bg-white shadow-md">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-3xl font-bold text-blue-700">
                BagNest
            </a>

            <a href="/shop"
               class="bg-blue-700 hover:bg-orange-700 text-white px-5 py-2 rounded-lg transition">
                Shop
            </a>
        </div>
    </nav>

    <!-- Profile Card -->
    <div class="flex justify-center items-center py-16 px-5">

        <div class="bg-white w-full max-w-xl rounded-2xl shadow-xl overflow-hidden">

            <!-- Header -->
            <div class="bg-blue-700 h-36 flex justify-center items-center">

                <div class="w-28 h-28 rounded-full bg-white flex items-center justify-center text-5xl font-bold text-blue-500 border-4 border-white shadow-lg">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>

            </div>

            <!-- Body -->
            <div class="p-8">

                <h2 class="text-3xl font-bold text-center text-gray-800">
                    <%= user.username %>
                </h2>

                <p class="text-center text-gray-500 mb-8">
                    Welcome to BagNest
                </p>

                <!-- Username -->
                <div class="mb-5">
                    <label class="block text-gray-500 text-sm mb-1">
                        Username
                    </label>

                    <div class="bg-gray-100 rounded-lg px-4 py-3 font-medium">
                        <%= user.username %>
                    </div>
                </div>

                <!-- Email -->
                <div class="mb-5">
                    <label class="block text-gray-500 text-sm mb-1">
                        Email
                    </label>

                    <div class="bg-gray-100 rounded-lg px-4 py-3 font-medium">
                        <%= user.email %>
                    </div>
                </div>

                <!-- Contact -->
                <div class="mb-8">
                    <label class="block text-gray-500 text-sm mb-1">
                        Contact
                    </label>

                    <div class="bg-gray-100 rounded-lg px-4 py-3 font-medium">
                        <%= user.contact %>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="grid gap-4">

                    <a href="/cart"
                       class="w-full bg-blue-700 hover:bg-orange-600 text-white text-center py-3 rounded-lg font-semibold transition">
                        🛒 View Cart
                    </a>

                    <a href="/profile/edit"
                       class="w-full border border-orange-500 text-orange-500 hover:bg-orange-500 hover:text-white text-center py-3 rounded-lg font-semibold transition">
                        Edit Profile
                    </a>

                    <a href="/logout"
                       class="w-full bg-red-500 hover:bg-red-600 text-white text-center py-3 rounded-lg font-semibold transition">
                        Logout
                    </a>

                </div>

            </div>

        </div>

    </div>

</body>
</html>